<UserControl x:Class="SmartFillMonitor.Views.AlarmsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SmartFillMonitor.Views"
             xmlns:converters="clr-namespace:SmartFillMonitor.Converters"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <converters:ZeroToVisbilityConverter x:Key="ZeroToVisbilityConverter"/>
            
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
            <TabControl Style="{StaticResource AppTabControlStyle}">
        <TabItem Header="活动报警" Style="{StaticResource AppTabItemStyle}">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 头部：标题 + 报警计数 + 刷新按钮 -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="当前活动报警" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AppTextMain}" VerticalAlignment="Center"/>
                        <Border Background="{StaticResource AppDanger}" CornerRadius="10" Padding="8,4" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ActiveAlarmCount}" FontSize="10" Foreground="White" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                    <Button Grid.Column="1" Content="刷新" Command="{Binding RefreshCommand}" Width="90" Style="{StaticResource OutLineButton}"/>
                </Grid>

                <!-- 报警列表 + 空状态覆盖层 -->
                <Grid Grid.Row="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ActiveAlarms}" Margin="0,0,0,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,10" Margin="0,0,0,8" Background="#1A1111" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="4,0,0,0" CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 左侧：报警信息 -->
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock FontWeight="Bold" FontSize="14" Foreground="#FFCCCC">
                                                    <Run Text="{Binding Code}"/><Run Text=": "/><Run Text="{Binding Title}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Description}" Margin="0,4,0,0" Foreground="#AAAAAA" FontSize="13" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <!-- 右侧：时间 + 操作按钮 -->
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="24,0,0,0" MinWidth="100">
                                                <TextBlock Text="{Binding TimeStr}" Foreground="#888888" FontSize="12" HorizontalAlignment="Right"/>
                                                <Button Content="确认/复位" Style="{StaticResource AppButtonStyle}"
                                                        Command="{Binding DataContext.AcknowledgeAlarmCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Margin="0,6,0,0" Background="#555555" Width="90" Height="30"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- 空状态提示 -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding ActiveAlarmCount, Converter={StaticResource ZeroToVisbilityConverter}}">
                        <TextBlock Text="✓" FontSize="48" Foreground="{StaticResource AppSuccess}" HorizontalAlignment="Center"/>
                        <TextBlock Text="当前无活动报警" FontSize="16" Foreground="{StaticResource AppTextMuted}" Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </TabItem>
        <TabItem Header="历史报警" Style="{StaticResource AppTabItemStyle}">
            <Grid Background="{StaticResource AppBgDark}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{StaticResource AppBgPanel}" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="12,12,12,8" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="开始时间" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <hc:DateTimePicker SelectedDateTime="{Binding HistoryStartTime,UpdateSourceTrigger=PropertyChanged}" FontSize="12" Padding="4"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="至" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <hc:DateTimePicker SelectedDateTime="{Binding HistoryEndTime,UpdateSourceTrigger=PropertyChanged}" FontSize="12" Padding="4"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="查询" Command="{Binding LoadHistoryAlarmsCommand}" Style="{StaticResource OutLineButton}" BorderBrush="Green" Width="80" Margin="10,0,8,0"></Button>
                        </StackPanel>

                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="{StaticResource AppBgPanel}" BorderThickness="1" CornerRadius="4" Margin="12,0,12,12">
                    <Grid>
                        <DataGrid ItemsSource="{Binding HistoryAlarms}" IsReadOnly="True" AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code" Binding="{Binding Code}"/>
                                <DataGridTextColumn Header="Title" Binding="{Binding Title}"/>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}"/>
                                <DataGridTextColumn Header="TriggerTime" Binding="{Binding TimerStr}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
