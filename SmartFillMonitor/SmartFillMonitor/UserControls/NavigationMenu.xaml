<UserControl x:Class="SmartFillMonitor.UserControls.NavigationMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SmartFillMonitor.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource AppBgPanel}" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="0,0,0,1" Padding="20,0">
            <TextBlock Text="Smart Fill Monitor" Foreground="{StaticResource AppAccentColor}" VerticalAlignment="Center" FontFamily="18" FontWeight="Bold"/>
        </Border>

        <StackPanel Grid.Row="1" Margin="0,10,0,0">
            <RadioButton Style="{StaticResource NavItemStyle}" GroupName="Nav" IsChecked="True" Command="{Binding DataContext.NavigateToDashBoardCommand,RelativeSource={RelativeSource AncestorType=Window}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="主页监控"/>
                </StackPanel>
            </RadioButton>

            <RadioButton Style="{StaticResource NavItemStyle}" GroupName="Nav" IsChecked="False" Command="{Binding DataContext.NavigateToDataQueryCommand,RelativeSource={RelativeSource AncestorType=Window}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="数据查询"/>
                </StackPanel>
            </RadioButton>

            <RadioButton Style="{StaticResource NavItemStyle}" GroupName="Nav" IsChecked="False" Command="{Binding DataContext.NavigateToLogsCommand,RelativeSource={RelativeSource AncestorType=Window}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="运行日志"/>
                </StackPanel>
            </RadioButton>

            <RadioButton Style="{StaticResource NavItemStyle}" GroupName="Nav" IsChecked="False" Command="{Binding DataContext.NavigateToAlarmsCommand,RelativeSource={RelativeSource AncestorType=Window}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="报警管理"/>
                </StackPanel>
            </RadioButton>

            <RadioButton Style="{StaticResource NavItemStyle}" GroupName="Nav" IsChecked="False" Command="{Binding DataContext.NavigateToSettingCommand,RelativeSource={RelativeSource AncestorType=Window}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="系统设置"/>
                </StackPanel>
            </RadioButton>
        </StackPanel>
    </Grid>
</UserControl>
